# CS2-Kit Source AMBuilder - Static library build definition

import os

# Source files, auto-discovered from src/.
SRC_DIR = os.path.join(builder.sourcePath, "src")

SOURCES = []
for root, dirs, files in os.walk(SRC_DIR):
    for f in files:
        if f.endswith(".cpp"):
            SOURCES.append(os.path.join(root, f))

SOURCES.sort()

# Build the static library.
for sdk_target in Library.sdk_targets:
    binary = Library.create_static_library(builder, sdk_target)

    # Standalone builds compiling src/Http/HttpClient.cpp must add a libcurl
    # include dir here; the source-inclusion build inherits it from the plugin.
    binary.sources += SOURCES

    if binary.compiler.like("msvc"):
        binary.compiler.linkflags += ["psapi.lib"]  # SigScanner: GetModuleInformation

    Library.binaries += [builder.Add(binary)]
