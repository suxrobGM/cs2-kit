{
  // Platform-specific byte patterns and offsets, resolved at runtime by the
  // signature scanner. Fragile: re-verify after every CS2 engine update.
  // Pattern syntax: space-separated hex, "?" = wildcard byte, "offset" = byte
  // distance from the match to the rel32 displacement (RIP-relative resolve).

  "offsets": {
    // Byte offset of the CGameEntitySystem* inside IGameResourceService.
    "GameEntitySystem": {
      "windows": 88,
      "linux": 80
    },
    // CBasePlayerPawn::CommitSuicide vtable index. Cross-checked vs SwiftlyS2
    // and cs2-menus; the earlier 400/400 hit an unrelated vfunc and crashed.
    "CommitSuicide": {
      "windows": 390,
      "linux": 390
    },
    // CCSPlayerController::ChangeTeam vtable index (SwiftlyS2: 103/102).
    // Earlier 101/101 hit CBaseEntity::ChangeTeam, which doesn't switch team.
    "ChangeTeam": {
      "windows": 103,
      "linux": 102
    },
    "Respawn": {
      "windows": 42,
      "linux": 42
    },
    // CBaseEntity::Teleport(origin, angles, velocity) vtable index
    // (SwiftlyS2: 163/162).
    "Teleport": {
      "windows": 163,
      "linux": 162
    },
    // Byte offset of the recipient player slot inside CCheckTransmitInfo
    // (the SDK declares only the two leading bitvec pointers). Synced from
    // CS2Fixes gamedata under the same name.
    "CheckTransmitPlayerSlot": {
      "windows": 576,
      "linux": 576
    },
    // CPlayer_MovementServices::RunCommand vtable index (SwiftlyS2: 22/23).
    // Drives Sdk::MovementHook - a wrong index calls an unrelated vfunc and crashes.
    "RunCommand": {
      "windows": 22,
      "linux": 23
    }
  },

  "signatures": {
    // CSource2Server::g_GameEventManager (IGameEventManager2*), rel32 at "offset".
    "GameEventManager": {
      "library": "server",
      "windows": {
        "pattern": "48 83 EC ? 48 83 3D ? ? ? ? ? 74 ? 33 C9 E8 ? ? ? ? FF 15 ? ? ? ?",
        "offset": 98
      },
      "linux": {
        "pattern": "55 48 89 E5 41 55 41 54 53 48 83 EC 08 48 8D 05 ? ? ? ? 48 83 38 00",
        "offset": 106
      }
    },

    // GetLegacyGameEventListener: IGameEventListener2*(*)(CPlayerSlot); match IS the function.
    "LegacyGameEventListener": {
      "library": "server",
      "windows": {
        "pattern": "48 8B 15 ? ? ? ? 48 85 D2 74 ? 83 F9 ? 77"
      },
      "linux": {
        "pattern": "48 8B 05 ? ? ? ? 48 85 C0 74 ? 83 FF ? 77 ? 48 63 FF 48 C1 E7 ? 48 8D 44 38"
      }
    },

    // ── Entity ops (EntityOpsService) ─────────────────────────────────
    // Patterns copied from CS2Fixes gamedata (github.com/Source2ZE/CS2Fixes)
    // under the same entry names - re-sync from there after CS2 updates.

    // CBaseEntity* (const char* className, int forceEdictIndex /* -1 */)
    "CreateEntityByName": {
      "library": "server",
      "windows": {
        "pattern": "48 83 EC 48 C6 44 24 30 00"
      },
      "linux": {
        "pattern": "48 8D 05 ? ? ? ? 55 48 89 FA"
      }
    },

    // void (CBaseEntity*, CEntityKeyValues* /* may be null */)
    "DispatchSpawn": {
      "library": "server",
      "windows": {
        "pattern": "48 89 5C 24 10 57 48 83 EC 30 48 8B DA 48 8B F9 48 85 C9"
      },
      "linux": {
        "pattern": "48 85 FF 74 ? 55 48 89 E5 41 55 41 54 49 89 FC"
      }
    },

    // void (CEntityInstance*, const char* input, activator, caller, variant_t*, int outputId, void*).
    // Not a vtable call in CS2.
    "CEntityInstance_AcceptInput": {
      "library": "server",
      "windows": {
        "pattern": "48 89 5C 24 ? 48 89 74 24 ? 57 48 83 EC ? 49 8B F0 48 8B D9 48 8B 0D"
      },
      "linux": {
        "pattern": "55 48 89 F0 48 89 E5 41 57 49 89 FF 41 56 48 8D 7D"
      }
    },

    // Deferred entity IO (delayed inputs, "Kill" cleanup):
    // void (CEntitySystem*, target, input, activator, caller, variant_t*, float delay, int outputId, void*, void*)
    "CEntitySystem_AddEntityIOEvent": {
      "library": "server",
      "windows": {
        "pattern": "48 89 5C 24 18 4C 89 4C 24 20 48 89 4C 24 08 55 56 57 41 54 41 55 41 56 41 57 48 83 EC 20"
      },
      "linux": {
        "pattern": "55 48 89 E5 41 55 49 89 CD 41 54 49 89 FC 53 BB"
      }
    },

    // void (CEntityInstance*) - immediate entity removal.
    "UTIL_Remove": {
      "library": "server",
      "windows": {
        "pattern": "48 85 C9 74 ? 48 8B D1 48 8B 0D ? ? ? ?"
      },
      "linux": {
        "pattern": "48 89 FE 48 85 FF 74 ? 48 8D 05 ? ? ? ? 48"
      }
    },

    // void (CBaseEntity*, const char* soundEvent, int pitch, float volume, float delay).
    // Vscript binding per CS2Fixes - may vanish; EmitSoundFilter is sturdier.
    "CBaseEntity_EmitSoundParams": {
      "library": "server",
      "windows": {
        "pattern": "48 89 5C 24 ? 48 89 74 24 ? 48 89 7C 24 ? 55 48 8B EC 48 81 EC ? ? ? ? 33 C0"
      },
      "linux": {
        "pattern": "48 B8 ? ? ? ? ? ? ? ? 55 0F 28 D0"
      }
    },

    // StartSoundEventInfo (IRecipientFilter&, CEntityIndex, const EmitSound_t&)
    "CBaseEntity_EmitSoundFilter": {
      "library": "server",
      "windows": {
        "pattern": "40 53 48 83 EC ? 4C 89 4C 24 ? 48 8B D9 45 8B C8"
      },
      "linux": {
        "pattern": "55 48 89 E5 53 48 89 FB 48 83 EC ? E8 ? ? ? ? 48 89 D8 48 8B 5D ? C9 C3 CC CC CC CC CC CC 48 B8"
      }
    },

    // void (CBaseModelEntity*, const char* modelPath)
    "CBaseModelEntity_SetModel": {
      "library": "server",
      "windows": {
        "pattern": "40 53 48 83 EC ? 48 8B D9 4C 8B C2 48 8B 0D ? ? ? ? 48 8D 54 24 ? 48 8B 01 FF 50 ? 48 8B 54 24 ? 48 8B CB E8 ? ? ? ? 48 83 C4 ? 5B C3 CC CC CC CC CC CC CC CC CC CC CC CC CC CC CC 48 89 5C 24"
      },
      "linux": {
        "pattern": "55 48 89 E5 53 48 89 FB 48 83 EC ? 48 8D 05 ? ? ? ? 48 8B 38 48 8B 07 FF 50 ? 48 89 DF 48 8B 5D ? C9 48 89 C6 E9 ? ? ? ? CC CC CC CC 55"
      }
    },

    // CBaseEntity* (CEntitySystem*, CEntityInstance* startAfter, const char* className)
    "CGameEntitySystem_FindEntityByClassName": {
      "library": "server",
      "windows": {
        "pattern": "48 83 EC 68 45 33 C9"
      },
      "linux": {
        "pattern": "55 45 31 C0 31 C9 48 89 E5 53 48 8D 5D ? 48 83 EC ? 48 89 DF"
      }
    },

    // CBaseEntity* (CEntitySystem*, startAfter, name, searching, activator, caller, IEntityFindFilter*)
    "CGameEntitySystem_FindEntityByName": {
      "library": "server",
      "windows": {
        "pattern": "48 81 EC 88 ? ? ? 4D 85 C0"
      },
      "linux": {
        "pattern": "55 48 89 E5 41 54 53 48 83 EC ? 48 85 D2"
      }
    },

    // ── Game-system registration (PrecacheService) ────────────────────
    // These resolve DATA pointers: "offset" points at the rel32 inside the
    // matched mov (3 opcode bytes for qword, 2 for dword).

    // CBaseGameSystemFactory** sm_pFirst - head of the engine's factory list.
    "IGameSystem_InitAllSystems_pFirst": {
      "library": "server",
      "windows": {
        "pattern": "48 8B 1D ? ? ? ? 48 85 DB 0F 84 ? ? ? ? BD",
        "offset": 3
      },
      "linux": {
        "pattern": "4C 8B 35 ? ? ? ? 4D 85 F6 75 ? E9",
        "offset": 3
      }
    },

    // CGameSystemEventDispatcher** - live dispatcher, for detach on unload.
    "IGameSystem_LoopPostInitAllSystems_pEventDispatcher": {
      "library": "server",
      "windows": {
        "pattern": "48 39 1D ? ? ? ? 74 ? 39 05",
        "offset": 3
      },
      "linux": {
        "pattern": "4C 8B 25 ? ? ? ? 48 8B 05 ? ? ? ? 8B 35",
        "offset": 3
      }
    },

    // CUtlVector<AddedGameSystem_t>* s_GameSystems - active systems, for removal on unload.
    "IGameSystem_LoopDestroyAllSystems_s_GameSystems": {
      "library": "server",
      "windows": {
        "pattern": "8B 05 ? ? ? ? 83 E8 ? 48 63 F8 0F 88",
        "offset": 2
      },
      "linux": {
        "pattern": "8B 05 ? ? ? ? 89 C2 83 EA ? 0F 88 ? ? ? ? 4C 8D 3D",
        "offset": 2
      }
    }
  }
}
